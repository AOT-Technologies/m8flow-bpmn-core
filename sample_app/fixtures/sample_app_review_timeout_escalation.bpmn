<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_sample_app_review_timeout_escalation"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="m8flow-bpmn-core"
  exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_sample_app_review_timeout_escalation">
    <bpmn:participant
      id="Participant_sample_app_review_timeout_escalation"
      name="Sample App Review Timeout Escalation"
      processRef="Process_sample_app_review_timeout_escalation"
    />
  </bpmn:collaboration>
  <bpmn:process
    id="Process_sample_app_review_timeout_escalation"
    name="Sample App Review Timeout Escalation"
    isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_operations" name="Operations">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_initial_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_review_timeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_reviewed_in_time</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_supervisor" name="Supervisor">
        <bpmn:flowNodeRef>Task_supervisor_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_supervisor_complete</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_start_to_initial_review</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:manualTask
      id="Task_initial_review"
      name="Review Submitted Request">
      <bpmn:incoming>Flow_start_to_initial_review</bpmn:incoming>
      <bpmn:outgoing>Flow_initial_review_to_end</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:boundaryEvent
      id="BoundaryEvent_review_timeout"
      name="Review Timeout"
      attachedToRef="Task_initial_review"
      cancelActivity="true">
      <bpmn:outgoing>Flow_timeout_to_supervisor</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration
          xsi:type="bpmn:tFormalExpression">'PT2M'</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask
      id="Task_supervisor_review"
      name="Supervisor Review">
      <bpmn:incoming>Flow_timeout_to_supervisor</bpmn:incoming>
      <bpmn:outgoing>Flow_supervisor_to_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent
      id="EndEvent_reviewed_in_time"
      name="Reviewed In Time">
      <bpmn:incoming>Flow_initial_review_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent
      id="EndEvent_supervisor_complete"
      name="Supervisor Review Complete">
      <bpmn:incoming>Flow_supervisor_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow
      id="Flow_start_to_initial_review"
      sourceRef="StartEvent_1"
      targetRef="Task_initial_review"
    />
    <bpmn:sequenceFlow
      id="Flow_initial_review_to_end"
      sourceRef="Task_initial_review"
      targetRef="EndEvent_reviewed_in_time"
    />
    <bpmn:sequenceFlow
      id="Flow_timeout_to_supervisor"
      sourceRef="BoundaryEvent_review_timeout"
      targetRef="Task_supervisor_review"
    />
    <bpmn:sequenceFlow
      id="Flow_supervisor_to_end"
      sourceRef="Task_supervisor_review"
      targetRef="EndEvent_supervisor_complete"
    />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane
      id="BPMNPlane_1"
      bpmnElement="Collaboration_sample_app_review_timeout_escalation">
      <bpmndi:BPMNShape
        id="Participant_sample_app_review_timeout_escalation_di"
        bpmnElement="Participant_sample_app_review_timeout_escalation"
        isHorizontal="true">
        <dc:Bounds x="120" y="100" width="1120" height="300" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="Lane_operations_di"
        bpmnElement="Lane_operations"
        isHorizontal="true">
        <dc:Bounds x="150" y="100" width="1090" height="150" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="Lane_supervisor_di"
        bpmnElement="Lane_supervisor"
        isHorizontal="true">
        <dc:Bounds x="150" y="250" width="1090" height="150" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="220" y="157" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="219" y="200" width="38" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="Task_initial_review_di"
        bpmnElement="Task_initial_review">
        <dc:Bounds x="340" y="135" width="200" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="BoundaryEvent_review_timeout_di"
        bpmnElement="BoundaryEvent_review_timeout">
        <dc:Bounds x="422" y="197" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="390" y="238" width="101" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="EndEvent_reviewed_in_time_di"
        bpmnElement="EndEvent_reviewed_in_time">
        <dc:Bounds x="660" y="157" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="624" y="200" width="109" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="Task_supervisor_review_di"
        bpmnElement="Task_supervisor_review">
        <dc:Bounds x="660" y="285" width="190" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="EndEvent_supervisor_complete_di"
        bpmnElement="EndEvent_supervisor_complete">
        <dc:Bounds x="970" y="307" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="916" y="350" width="145" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge
        id="Flow_start_to_initial_review_di"
        bpmnElement="Flow_start_to_initial_review">
        <di:waypoint x="256" y="175" />
        <di:waypoint x="340" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge
        id="Flow_initial_review_to_end_di"
        bpmnElement="Flow_initial_review_to_end">
        <di:waypoint x="540" y="175" />
        <di:waypoint x="660" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge
        id="Flow_timeout_to_supervisor_di"
        bpmnElement="Flow_timeout_to_supervisor">
        <di:waypoint x="440" y="233" />
        <di:waypoint x="440" y="325" />
        <di:waypoint x="660" y="325" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge
        id="Flow_supervisor_to_end_di"
        bpmnElement="Flow_supervisor_to_end">
        <di:waypoint x="850" y="325" />
        <di:waypoint x="970" y="325" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
