    <bpmn:sequenceFlow id="Flow_07e48pm" name="Expense Claim Rejected" sourceRef="Gateway_0dhl21r" targetRef="Event_0mumwd3">
      <bpmn:conditionExpression>decision == "Rejected"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1rj2fuy" name="Approved" sourceRef="Gateway_0dhl21r" targetRef="Activity_08g01ho">
      <bpmn:conditionExpression>decision == "Approved"</bpmn:conditionExpression>
