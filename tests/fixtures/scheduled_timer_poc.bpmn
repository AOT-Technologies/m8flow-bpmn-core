<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Scheduled_Timer_POC"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="m8flow-bpmn-core"
  exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_scheduled_timer_poc">
    <bpmn:participant
      id="Participant_scheduled_timer_poc"
      processRef="Process_scheduled_timer_poc"
    />
  </bpmn:collaboration>
  <bpmn:process
    id="Process_scheduled_timer_poc"
    name="Scheduled Timer POC"
    isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Operations" name="Operations">
        <bpmn:flowNodeRef>StartEvent_timer_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_timer_start" name="StartEvent_timer_start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDate
          xsi:type="bpmn:tFormalExpression">'__TIMER_DUE_AT__'</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:sequenceFlow
      id="Flow_1"
      sourceRef="StartEvent_timer_start"
      targetRef="Task_review"
    />
    <bpmn:userTask id="Task_review" name="Acknowledge Scheduled Job">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_review" targetRef="EndEvent_1" />
    <bpmn:endEvent id="EndEvent_1">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane
      id="BPMNPlane_1"
      bpmnElement="Collaboration_scheduled_timer_poc">
      <bpmndi:BPMNShape
        id="Participant_scheduled_timer_poc_di"
        bpmnElement="Participant_scheduled_timer_poc"
        isHorizontal="true">
        <dc:Bounds x="140" y="100" width="640" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="Lane_Operations_di"
        bpmnElement="Lane_Operations"
        isHorizontal="true">
        <dc:Bounds x="170" y="100" width="610" height="220" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="StartEvent_timer_start_di"
        bpmnElement="StartEvent_timer_start">
        <dc:Bounds x="240" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="202" y="235" width="113" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_review_di" bpmnElement="Task_review">
        <dc:Bounds x="360" y="175" width="140" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="600" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="276" y="210" />
        <di:waypoint x="360" y="215" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="500" y="215" />
        <di:waypoint x="600" y="210" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
