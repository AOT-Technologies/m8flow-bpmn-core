<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Scheduled_Boundary_Timer_POC"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="m8flow-bpmn-core"
  exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_scheduled_boundary_timer_poc">
    <bpmn:participant
      id="Participant_scheduled_boundary_timer_poc"
      processRef="Process_scheduled_boundary_timer_poc"
    />
  </bpmn:collaboration>
  <bpmn:process
    id="Process_scheduled_boundary_timer_poc"
    name="Scheduled Boundary Timer POC"
    isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Operations" name="Operations">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_timeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_timeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_timeout</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_review" />
    <bpmn:userTask id="Task_review" name="Review Before Timeout">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_review_done</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent
      id="BoundaryEvent_timeout"
      name="BoundaryEvent_timeout"
      attachedToRef="Task_review"
      cancelActivity="true">
      <bpmn:outgoing>Flow_timeout</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDate
          xsi:type="bpmn:tFormalExpression">'__BOUNDARY_TIMER_DUE_AT__'</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow
      id="Flow_review_done"
      sourceRef="Task_review"
      targetRef="EndEvent_review"
    />
    <bpmn:endEvent id="EndEvent_review">
      <bpmn:incoming>Flow_review_done</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow
      id="Flow_timeout"
      sourceRef="BoundaryEvent_timeout"
      targetRef="Task_timeout"
    />
    <bpmn:userTask id="Task_timeout" name="Handle Timeout Escalation">
      <bpmn:incoming>Flow_timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_timeout_done</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow
      id="Flow_timeout_done"
      sourceRef="Task_timeout"
      targetRef="EndEvent_timeout"
    />
    <bpmn:endEvent id="EndEvent_timeout">
      <bpmn:incoming>Flow_timeout_done</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane
      id="BPMNPlane_1"
      bpmnElement="Collaboration_scheduled_boundary_timer_poc">
      <bpmndi:BPMNShape
        id="Participant_scheduled_boundary_timer_poc_di"
        bpmnElement="Participant_scheduled_boundary_timer_poc"
        isHorizontal="true">
        <dc:Bounds x="140" y="100" width="900" height="240" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="Lane_Operations_di"
        bpmnElement="Lane_Operations"
        isHorizontal="true">
        <dc:Bounds x="170" y="100" width="870" height="240" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="240" y="202" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_review_di" bpmnElement="Task_review">
        <dc:Bounds x="360" y="180" width="170" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape
        id="BoundaryEvent_timeout_di"
        bpmnElement="BoundaryEvent_timeout">
        <dc:Bounds x="448" y="242" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="404" y="285" width="125" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_review_di" bpmnElement="EndEvent_review">
        <dc:Bounds x="630" y="202" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_timeout_di" bpmnElement="Task_timeout">
        <dc:Bounds x="620" y="60" width="180" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_timeout_di" bpmnElement="EndEvent_timeout">
        <dc:Bounds x="890" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="276" y="220" />
        <di:waypoint x="360" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_review_done_di" bpmnElement="Flow_review_done">
        <di:waypoint x="530" y="220" />
        <di:waypoint x="630" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_timeout_di" bpmnElement="Flow_timeout">
        <di:waypoint x="466" y="242" />
        <di:waypoint x="466" y="100" />
        <di:waypoint x="620" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_timeout_done_di" bpmnElement="Flow_timeout_done">
        <di:waypoint x="800" y="100" />
        <di:waypoint x="890" y="100" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
