M8FLOW_DATABASE_URL=sqlite+pysqlite:///./m8flow.db
M8FLOW_DATABASE_ECHO=false
# Optional: point test runs at a dedicated PostgreSQL database.
# If unset, the test suite uses a temporary SQLite database by default.
# M8FLOW_TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/m8flow_bpmn_core_test
# Optional: override the Docker image used by the local integration smoke test.
# M8FLOW_TEST_POSTGRES_IMAGE=postgres:16
# Optional: point the interactive conditional-approval example at Postgres.
# M8FLOW_EXAMPLE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/m8flow_bpmn_core_example
# Optional: override the Docker image used by the launcher when it needs a temporary database.
# M8FLOW_EXAMPLE_POSTGRES_IMAGE=postgres:16
