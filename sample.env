M8FLOW_DATABASE_URL=sqlite+pysqlite:///./m8flow.db
M8FLOW_DATABASE_ECHO=false
# Optional: point test runs at a dedicated PostgreSQL database.
# If unset, the test suite uses a temporary SQLite database by default.
# M8FLOW_TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/m8flow_bpmn_core_test
# Optional: override the Docker image used by the local integration smoke test.
# M8FLOW_TEST_POSTGRES_IMAGE=postgres:16
# Optional: point the interactive conditional-approval example at Postgres.
# M8FLOW_EXAMPLE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/m8flow_bpmn_core_example
# Optional: override the Docker image used by the launcher when it needs a temporary database.
# M8FLOW_EXAMPLE_POSTGRES_IMAGE=postgres:16
# Optional: point the Celery scheduler POC at a Redis broker.
# If you reuse the local m8flow Docker stack, the host default is usually:
# M8FLOW_BPMN_CORE_CELERY_BROKER_URL=redis://localhost:6848/0
# Optional: result backend for the Celery scheduler POC.
# Defaults to the broker URL when omitted.
# M8FLOW_BPMN_CORE_CELERY_RESULT_BACKEND=redis://localhost:6848/0
# Optional: dedicated queue name for the Celery scheduler POC.
# M8FLOW_BPMN_CORE_CELERY_QUEUE=m8flow-bpmn-core-poc
# Optional: polling interval in seconds for the periodic Celery task.
# M8FLOW_BPMN_CORE_CELERY_POLL_SECONDS=1
# Optional: dedicated DB URL for the Celery worker.
# Falls back to M8FLOW_EXAMPLE_DATABASE_URL, then M8FLOW_DATABASE_URL.
# M8FLOW_BPMN_CORE_CELERY_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:6843/postgres?connect_timeout=1
